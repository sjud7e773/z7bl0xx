# ═══════════════════════════════════════════
# z7Blox — Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local

# ── Supabase ──────────────────────────────
# URL do projeto (público)
NEXT_PUBLIC_SUPABASE_URL=https://wjmvmyenwniouvzuwyxm.supabase.co
# Anon key — pública, usada no client-side para ler products
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Service role key — PRIVADA, usada no webhook/checkout para inserir orders
# Pegue em: https://supabase.com/dashboard/project/wjmvmyenwniouvzuwyxm/settings/api
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Stripe ────────────────────────────────
# Secret key — PRIVADA, nunca expor no frontend
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret — configurar quando publicar o site
# Stripe Dashboard > Developers > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Site ──────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
